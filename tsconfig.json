{
  "extends": ["./configs/tsconfig/tsconfig.type-check.json"],
  "compilerOptions": {
    "paths": {
      "ts-type-forge": ["./src/index.mts"],
      "ts-type-forge/global": ["./src/global.mts"]
    }
  },
  "include": [
    "./src",
    "./samples",
    "./scripts",
    "./configs",
    "./.eslintrc.cjs",
    "./eslint.config.mts",
    "./release.config.js",
    "./.markdownlint-cli2.mjs"
  ],
  "exclude": ["src/global.mts"]
}
